generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Servicio {
  id              String   @id @default(cuid())
  nombre          String
  precio          Float
  duracion        Int      // en minutos
  nota            String?  // ej: "Solo lunes y martes"
  diasDisponibles Int[]    // 0=Dom…6=Sáb; vacío = todos los días
  activo          Boolean  @default(true)
  citas           Cita[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  telefono  String   @unique
  email     String?
  notas     String?
  citas     Cita[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cita {
  id          String      @id @default(cuid())
  fecha       DateTime
  hora        String      // "11:00"
  nombre      String
  telefono    String
  email       String?
  servicio    Servicio    @relation(fields: [servicioId], references: [id])
  servicioId  String
  cliente     Cliente?    @relation(fields: [clienteId], references: [id])
  clienteId   String?
  estado              EstadoCita  @default(PENDIENTE)
  notas               String?
  recordatorioEnviado Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@unique([fecha, hora])
}

model HorarioFranja {
  id        String  @id @default(cuid())
  diaSemana Int     // 0=domingo, 1=lunes, ..., 6=sábado
  inicio    String  // "10:00"
  fin       String  // "14:00"
  activo    Boolean @default(true)

  @@index([diaSemana])
}

model DiaCerrado {
  id     String   @id @default(cuid())
  fecha  DateTime @unique
  motivo String?
}

model DiaAbierto {
  id     String   @id @default(cuid())
  fecha  DateTime @unique
  motivo String?
}

model Ausencia {
  id      String   @id @default(cuid())
  inicio  DateTime
  fin     DateTime
  motivo  String?
  createdAt DateTime @default(now())

  @@index([inicio])
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

model AuditLog {
  id        String   @id @default(cuid())
  accion    String   // "HORARIO_ACTUALIZADO", "SERVICIO_CREADO", "CITA_CANCELADA", etc.
  entidad   String   // "HorarioFranja", "Servicio", "Cita"
  entidadId String?  // ID del recurso afectado (nullable para operaciones masivas)
  datos     Json?    // snapshot de los cambios realizados
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entidad])
}

model AdminCredential {
  id           String   @id @default("singleton")
  passwordHash String   // scrypt hash: "salt:derivedKey" (hex)
  updatedAt    DateTime @updatedAt
}

model PushSuscripcion {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
